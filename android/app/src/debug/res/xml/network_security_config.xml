<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY. Allows cleartext (http/ws) traffic to a local Convex backend
  during development. Not included in release builds, so production stays
  HTTPS-only.
    - 10.0.2.2  : the host machine as seen from the Android emulator
    - 127.0.0.1 / localhost : on-device / port-forwarded setups
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
